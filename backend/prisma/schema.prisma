generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  telegramId String    @unique
  createdAt  DateTime  @default(now())

  messages   Message[]
}

model Message {
  id        String   @id @default(uuid())
  role      String   // "user" | "assistant"
  content   String

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // Связь вопрос-ответ
  parentId  String?  // ID сообщения-вопроса (null для вопросов)
  parent    Message? @relation("QuestionAnswer", fields: [parentId], references: [id])
  replies   Message[] @relation("QuestionAnswer")

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([parentId])
}
